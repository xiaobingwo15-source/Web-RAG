# OpenRouter
MODEL_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-v4-flash:free

# Mistral chat generation (optional alternative to OpenRouter)
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-large-latest

# Google AI Studio (embeddings only)
GOOGLE_API_KEY=your-google-ai-studio-api-key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OWNER_API_KEY=generate-a-long-random-owner-key
WIDGET_TOKEN_SECRET=generate-a-long-random-widget-token-secret

# Tavly Web Search (Module 7 fallback)
TAVLY_API_KEY=tvly-dev-...

# Cohere Reranker (free tier)
COHERE_API_KEY=your-cohere-api-key

# Langfuse Observability (free tier: 50k observations/month)
# Regions: EU=https://cloud.langfuse.com | US=https://us.cloud.langfuse.com | JP=https://jp.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# Qdrant Vector Database
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Backend
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
