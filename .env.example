# OpenRouter
MODEL_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-v4-flash:free
OCR_MODEL=google/gemini-2.5-flash-lite
PDF_MAX_BYTES=10485760
PDF_MAX_PAGES=100
PDF_OCR_MAX_PAGES=20
PDF_LAYOUT_MAX_PAGES=30

# Mistral chat generation (optional alternative to OpenRouter)
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-large-latest

# Google AI Studio (embeddings only)
GOOGLE_API_KEY=your-google-ai-studio-api-key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PROJECT_REF=your-project
PRODUCTION_SUPABASE_PROJECT_REF=your-production-project
# Deprecated: OWNER_API_KEY/browser X-Owner-Key calls are no longer used.
OWNER_API_KEY=
OWNER_USER_EMAILS=owner@example.com
WIDGET_TOKEN_SECRET=generate-a-long-random-widget-token-secret

# Embeddings (gemini | jina | local_sentence_transformers)
EMBEDDING_PROVIDER=jina
JINA_API_KEY=jina_your-jina-api-key
JINA_EMBEDDING_MODEL=jina-embeddings-v5-text-small
EMBEDDING_DIMENSION=768

# Tavly Web Search (Module 7 fallback)
TAVLY_API_KEY=tvly-dev-...

# Cohere Reranker (free tier)
COHERE_API_KEY=your-cohere-api-key

# Langfuse Observability (free tier: 50k observations/month)
# Regions: EU=https://cloud.langfuse.com | US=https://us.cloud.langfuse.com | JP=https://jp.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# Qdrant Vector Database
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Backend
APP_ENV=local
# Test-only override for isolated CI fixtures; never enable for local/staging real data.
ALLOW_NONPROD_PRODUCTION_SUPABASE=false
SQL_TOOLS_ENABLED=false
ENABLE_API_DOCS=false
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
